# ── API SOC — config (a remplir, copier en .env) ────────────────────────────
# Ce backend tourne SUR ta machine, a cote de Postgres et d'Ollama.
# Il accede donc a la DB et au modele en localhost.

# --- Base de donnees (creee avec schema.sql) ---
DATABASE_URL=postgresql://soc_user:MOT_DE_PASSE@localhost:5432/soc

# --- Ollama (TON modele local) ---
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# --- Serveur ---
PORT=8000
# Origine autorisee (le dashboard). * en labo, sinon http://IP_ANALYSTE:5173
CORS_ORIGIN=*

# --- Optionnel : reponse / escalade (si tu les geres aussi) ---
PFSENSE_URL=
PFSENSE_TOKEN=
THEHIVE_URL=
THEHIVE_TOKEN=
